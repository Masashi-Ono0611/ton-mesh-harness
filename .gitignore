node_modules/
dist/
*.tgz

# Local secrets / E2E env — only .env.example is tracked
.env
.env.local

# Example build outputs (examples/ are clone-and-run; node_modules/ + dist/
# are already ignored globally above — these cover the framework-specific ones)
examples/*/out/
examples/*/.next/
examples/*/.astro/
# provenance manifest written at deploy time (a domain deploy injects
# .well-known/ton-deploy.json into source_dir). The e2e driver deploys from a
# tmp copy (#121), but cover the committed fixtures too as belt-and-suspenders.
examples/*/.well-known/
test/fixtures/*/.well-known/

# OS / editor / agent metadata — never belongs in the repo
.DS_Store
.claude/
