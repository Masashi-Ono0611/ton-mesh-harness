# ─────────────────────────────────────────────────────────────────────────
# E2E acceptance (V3 / #18) — scripts/e2e-mcp-deploy.cjs
#
# SECURITY: there is deliberately NO seed / mnemonic / private_key variable
# here. The agentic signing key lives in the @ton/mcp-managed config file
# (~/.config/ton/config.json, or $TON_CONFIG_PATH), written via @ton/mcp's
# wallet setup. The E2E driver reads that config the same way the real
# agent flow does — never a raw key from the environment. Do NOT add a
# mainnet seed to a dotenv file.
# ─────────────────────────────────────────────────────────────────────────

# Arm the real MAINNET deploy stage. Pick exactly ONE signing path below.
# Unset both => the driver runs stage 1 only (handshake + tools/list +
# check_env) and gracefully skips the deploy. The v0.8 MCP path is
# mainnet-only — testnet is rejected by the SDK (see docs/v0.8/e2e-runbook.md).
# A real deploy spends mainnet TON.

# Human-approved signing: surfaces the awaiting_signature URL + a terminal QR;
# you approve in Tonkeeper. No key stored anywhere. Recommended for V3.
E2E_TONCONNECT=

# Agentic (autonomous) signing — requires a configured @ton/mcp wallet.
E2E_AUTO_SIGN=

# Also run the cancellation-hygiene stage (start a deploy, send
# notifications/cancelled mid-flight, assert no leaked daemon process).
# Requires E2E_AUTO_SIGN=1.
E2E_CANCEL=

# A real mainnet .ton domain the configured agentic wallet controls. When
# set, the deploy writes DNS records and the driver asserts a non-null
# dns_tx_hash. When empty, the deploy is storage-only (dns_tx_hash null).
E2E_MAINNET_DOMAIN=

# Override path to the agentic-wallet config. Falls back to
# ~/.config/ton/config.json. Point this at a dedicated test config to keep
# the E2E run isolated from your day-to-day wallet.
TON_CONFIG_PATH=

# Gate for the Vitest wrapper (test/mcp-e2e.test.ts). The default `bun run test`
# run skips it; set to 1 to include it (requires `bun run build` first).
RUN_MCP_E2E=
