{
  "name": "ton-sovereign-deploy",
  "version": "0.8.0-rc1",
  "description": "Sovereign one-command CLI to deploy a static site to .ton (TON Storage + .ton DNS + ADNL), self-host first. v0.8.0 GA will add an MCP server (ton-sovereign-mcp) for agent-callable invocation; v0.8.0-rc1 ships the CLI + agent-quickstart docs only.",
  "main": "./dist/cli.js",
  "bin": {
    "ton-sovereign-deploy": "dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ton",
    "ton-storage",
    "ton-dns",
    "dot-ton",
    "adnl",
    "blockchain",
    "deploy",
    "static-site",
    "website",
    "storage",
    "decentralized-web",
    "censorship-resistant",
    "mcp",
    "mcp-server",
    "agent-skill",
    "claude-skill",
    "tonconnect",
    "agentic-wallet"
  ],
  "license": "MIT",
  "dependencies": {
    "@ton/ton": "^15.4.0",
    "@tonconnect/sdk": "^3.4.1",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "ora": "^5.4.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
