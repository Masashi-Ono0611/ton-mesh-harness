{
  "name": "ton-sovereign-deploy",
  "version": "0.8.0-rc10",
  "description": "Sovereign one-command CLI + MCP server to deploy a static site to .ton (TON Storage + .ton DNS + ADNL), self-host first, agent-callable. v0.8.0-rc10 — full v0.8 feature ship + 11 Codex multi-model review rounds (4 BLOCKERs + 20 MAJORs + 3 MINORs + 4 NITs + 1 LOW resolved). Incl. binary-download SHA-256 integrity, TonConnect signed-BOC stderr leak, wallet-key symlink redirect, daemon orphan-on-signal, http body size cap. 3 MCP tools, SDK external entry, NFT-delegated agentic signing.",
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "default": "./dist/sdk.js"
    },
    "./sdk": {
      "types": "./dist/sdk.d.ts",
      "default": "./dist/sdk.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ton-sovereign-deploy": "dist/cli.js",
    "ton-sovereign-mcp": "dist/mcp.js"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/sdk",
    "smoke": "node scripts/cli-smoke.cjs && node scripts/mcp-smoke.cjs && node scripts/sdk-smoke.cjs",
    "smoke:full": "npm run smoke && node scripts/tarball-smoke.cjs",
    "verify": "npm run lint && tsc --noEmit && npm test && npm run build && npm run smoke",
    "pack:dry": "npm pack --dry-run"
  },
  "files": [
    "dist",
    "templates",
    "skills"
  ],
  "keywords": [
    "ton",
    "ton-storage",
    "ton-dns",
    "dot-ton",
    "adnl",
    "blockchain",
    "deploy",
    "static-site",
    "website",
    "storage",
    "decentralized-web",
    "censorship-resistant",
    "mcp",
    "mcp-server",
    "agent-skill",
    "claude-skill",
    "tonconnect",
    "agentic-wallet"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ton/ton": "^15.4.0",
    "@ton/walletkit": "^0.0.12-alpha.3",
    "@tonconnect/sdk": "^3.4.1",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "ora": "^5.4.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@ton/mcp": "^0.1.15-alpha.15"
  },
  "peerDependenciesMeta": {
    "@ton/mcp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ton/mcp": "^0.1.15-alpha.15",
    "@types/chokidar": "^1.7.5",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.9",
    "zod-to-json-schema": "^3.25.2"
  }
}
