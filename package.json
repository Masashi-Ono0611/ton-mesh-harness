{
  "name": "ton-sovereign-deploy",
  "version": "0.8.0-rc2",
  "description": "Sovereign one-command CLI + MCP server to deploy a static site to .ton (TON Storage + .ton DNS + ADNL), self-host first, agent-callable. v0.8.0-rc2 ships the MCP server bootstrap (bag-upload core); .ton DNS write lands in CLI today and in the SDK at v0.8.0 GA.",
  "main": "./dist/cli.js",
  "bin": {
    "ton-sovereign-deploy": "dist/cli.js",
    "ton-sovereign-mcp": "dist/mcp.js"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/sdk"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ton",
    "ton-storage",
    "ton-dns",
    "dot-ton",
    "adnl",
    "blockchain",
    "deploy",
    "static-site",
    "website",
    "storage",
    "decentralized-web",
    "censorship-resistant",
    "mcp",
    "mcp-server",
    "agent-skill",
    "claude-skill",
    "tonconnect",
    "agentic-wallet"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ton/ton": "^15.4.0",
    "@ton/walletkit": "^0.0.12-alpha.3",
    "@tonconnect/sdk": "^3.4.1",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "ora": "^5.4.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.9",
    "zod-to-json-schema": "^3.25.2"
  }
}
