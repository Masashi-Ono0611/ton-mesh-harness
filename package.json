{
  "name": "ton-sovereign-deploy",
  "version": "0.4.0",
  "description": "Deploy static sites to TON Storage in one command",
  "main": "./dist/cli.js",
  "bin": {
    "ton-sovereign-deploy": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ton",
    "blockchain",
    "deploy",
    "storage",
    "censorship-resistant"
  ],
  "license": "MIT",
  "dependencies": {
    "@ton/ton": "^15.4.0",
    "@tonconnect/sdk": "^3.4.1",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "ora": "^5.4.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
